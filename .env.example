# Copy to .env.local and fill in real values.
# Launch: ./start.sh   (or npm run dev)

# ─── Stripe mode switch ─────────────────────────────────────────────────────
# false = test (safe) | true = LIVE real charges
# Keep both in sync (server + browser).
STRIPE_LIVE_MODE=false
NEXT_PUBLIC_STRIPE_LIVE_MODE=false

# Test keys (Dashboard → toggle Test mode ON)
STRIPE_SECRET_KEY_TEST=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...

# Live keys (Dashboard → toggle Test mode OFF)
STRIPE_SECRET_KEY_LIVE=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...

# Optional: classic aliases (used as fallback if _TEST/_LIVE missing)
# Prefer leaving these equal to the active mode keys.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhooks (optional on localhost — success page also sends emails after pay)
# Endpoint: https://www.lilyssweettreatsva.com/api/webhooks/stripe
# Event: payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=whsec_...
# Or mode-specific:
# STRIPE_WEBHOOK_SECRET_TEST=whsec_...
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...

# Resend (https://resend.com) — owner + customer emails after payment
RESEND_API_KEY=re_...

# Branded From (domain verified in Resend)
EMAIL_FROM="Lily's Sweet Treats <orders@lilyssweettreatsva.com>"

# Who gets new-order alerts (Lily)
ORDER_NOTIFY_EMAIL=sweettreats0077@gmail.com
