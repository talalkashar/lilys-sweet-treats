# Copy to .env.local and fill in real values.
# Launch: ./start.sh   (or npm run dev)

# Stripe (Dashboard → Developers → API keys)
# Use pk_test_ / sk_test_ while building; switch to live keys before real sales
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (Dashboard → Developers → Webhooks)
# Endpoint: https://www.lilyssweettreatsva.com/api/webhooks/stripe
# Event: payment_intent.succeeded
# (Optional on localhost — success page also sends emails after pay)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (https://resend.com) — owner + customer emails after payment
# Required for confirmation emails on localhost. Without it, checkout still works.
RESEND_API_KEY=re_...

# Branded From (domain verified in Resend)
EMAIL_FROM="Lily's Sweet Treats <orders@lilyssweettreatsva.com>"

# Who gets new-order alerts (Lily)
ORDER_NOTIFY_EMAIL=sweettreats0077@gmail.com
